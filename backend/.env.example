PORT=4000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>

CLOUDINARY_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_SECRET_KEY=<secret-key>

JWT_SECRET=<long-random-secret>
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-admin-password>

STRIPE_SECRET_KEY=<stripe-secret-key>

# Set to your deployed frontend URL (e.g. https://your-app.vercel.app).
# Leave blank to default to http://localhost:5173 in development.
FRONTEND_URL=

# Comma-separated list of allowed CORS origins.
# Leave blank to allow all origins (development only).
ALLOWED_ORIGINS=
